@Article{Kim2014Linear,
  abbr            = {journal},
  author          = {Kim, Hyungjong and Shim, Hyungbo},
  journal         = {IET Control Theory & Applications},
  title           = {Linear Systems with Hyperbolic Zero Dynamics Admit Output Regulator Rejecting Unknown Number of Unknown Sinusoids},
