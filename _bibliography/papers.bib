@Article{Back2013Reducedo,
  author          = {Back, Juhoon and Shim, Hyungbo},
  journal         = {IET Control Theory & Applications},
  title           = {Reduced-Order Implementation of Disturbance Observers for Robust Tracking of Nonlinear Systems},
